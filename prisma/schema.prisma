// 1. Configuração do Gerador
generator client {
  provider = "prisma-client-js"
}

// 2. Configuração da Conexão
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 3. Modelo de Usuário Completo
model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String
  
  // Campos Militares
  posto     String?  @default("Soldado")
  re        String?  @unique
  unidade   String?  @default("17º BPM")
  setor     String?
  telefone  String?
  
  // Campo para Foto 
  image     String?  

  // Controle de Acesso
  nivel     String?  @default("Operador")
  status    String?  @default("Ativo")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Item {
  id          String   @id @default(cuid())
  categoria   String   
  descricao   String   
  pmpr        String?  @unique 
  serie       String?          
  quantidade  Int      @default(1)
  status      String   @default("Disponível")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("itens")
}

model Relatorio {
  id          Int      @id @default(autoincrement())
  hash        String   @unique  
  responsavel String            
  data        String            
  hora        String   
  pdfUrl      String?        
  createdAt   DateTime @default(now())
}