// 1. Configuração do Gerador
generator client {
  provider = "prisma-client-js"
}

// 2. Configuração da Conexão (ESTE É O BLOCO QUE O ERRO DIZ QUE FALTA)
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 3. Modelo de Usuário Completo
model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String
  
  posto     String?   @default("Soldado")
  re        String?   @unique
  
  // Novos campos que incluímos
  nivel     String?   @default("Operador")
  status    String?   @default("Ativo")

  unidade   String?   @default("17º BPM")
  setor     String?
  telefone  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}