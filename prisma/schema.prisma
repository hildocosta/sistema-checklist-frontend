// 1. Configuração do Gerador
generator client {
  provider = "prisma-client-js"
}

// 2. Configuração da Conexão
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 3. Modelo de Usuário Completo
model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String
  
  // Campos Militares
  posto     String?  @default("Soldado")
  re        String?  @unique
  unidade   String?  @default("17º BPM")
  setor     String?
  telefone  String?
  
  // Campo para Foto (ESSENCIAL PARA O VERCEL BLOB)
  image     String?  

  // Controle de Acesso
  nivel     String?  @default("Operador")
  status    String?  @default("Ativo")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}