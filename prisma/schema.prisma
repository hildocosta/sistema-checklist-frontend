// 1. Configuração do Gerador
generator client {
  provider = "prisma-client-js"
}

// 2. Configuração da Conexão
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 3. Seu Modelo de Usuário Atualizado
model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  password  String
  
  posto     String?   @default("Soldado")
  re        String?   @unique
  unidade   String?   @default("17º BPM")
  setor     String?
  telefone  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}